# OS / editor
.vs/
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------
# .NET build artifacts
# -----------------------------
**/bin/
**/obj/
**/TestResults/
*.user
*.suo

# EF / local SQLite runtime sidecars
*.db-shm
*.db-wal

# Local development databases
*.db

# -----------------------------
# Frontend artifacts
# -----------------------------
**/node_modules/
**/dist/
**/dist-ssr/
**/coverage/
**/.vite/
**/test-results/
**/playwright-report/

# Vite / TS local files
**/*.tsbuildinfo
*.local
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

publish/
deploy.zip
